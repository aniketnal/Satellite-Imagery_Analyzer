# Sample environment file for the backend service
# Copy this to `.env` in the `backend/` folder and fill real secrets.
# Do NOT commit your real `.env` to source control.

# --- Supabase (Postgres) ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=service_role_key_here
SUPABASE_ANON_KEY=anon_public_key_here

# --- Admin account (used by initial seeding / admin login) ---
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=ChangeThisPassword

# --- SMTP (for authority alert emails) ---
SMTP_USER=your_gmail_address@gmail.com
SMTP_PASSWORD=your_gmail_app_password

# Authority alerting
AUTHORITY_ALERT_EMAIL=nmc@gov.in
AUTHORITY_ALERT_USS_THRESHOLD=1
AUTHORITY_ALERT_DEFORESTATION_THRESHOLD=-10

# --- Google / Earth Engine / Gemini keys (optional) ---
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=text-bison


# Optional: frontend should point to backend API base (useful when running frontend separately)
# The frontend uses Vite env variables; set this in frontend/.env or override here if you prefer.
VITE_API_BASE_URL=http://localhost:5000
